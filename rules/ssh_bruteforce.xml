<?xml version="1.0" encoding="UTF-8"?>
<ruleset>

  <!-- 
    RULE SET: SSH Brute Force Detection
    Author: Security Engineer
    MITRE: T1110 (Brute Force), T1110.003 (Password Spraying)
  -->

  <group name="ssh_bruteforce,">

    <!-- Count failed SSH attempts per source IP -->
    <rule id="100001" level="0" frequency="5" timeframe="60" noalert="1">
      <if_matched_sid>5710</if_matched_sid>
      <same_source_ip />
      <description>SSH brute force pattern detected</description>
    </rule>

    <!-- Alert on brute force in progress -->
    <rule id="100002" level="10" frequency="5" timeframe="60">
      <if_matched_sid>5710</if_matched_sid>
      <same_source_ip />
      <description>SSH brute force attack in progress</description>
      <mitre>
        <id>T1110</id>
        <tactic>Credential Access</tactic>
      </mitre>
    </rule>

    <!-- CRITICAL: Brute force succeeded -->
    <rule id="100003" level="15">
      <if_matched_sid>100001</if_matched_sid>
      <if_sid>5715</if_sid>
      <description>SSH brute force succeeded - potential compromise!</description>
      <mitre>
        <id>T1110.003</id>
        <tactic>Credential Access</tactic>
      </mitre>
    </rule>

    <!-- Detect slow brute force (over 5 minutes) -->
    <rule id="100004" level="8" frequency="10" timeframe="300">
      <if_matched_sid>5710</if_matched_sid>
      <same_source_ip />
      <description>Slow SSH brute force attack (low and slow)</description>
    </rule>

  </group>

</ruleset>
